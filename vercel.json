{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@5.0.0",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/ping",
      "destination": "/api/index.js"
    },
    {
      "source": "/loading.png",
      "destination": "/public/loading.png"
    },
    {
      "source": "/coinix.png",
      "destination": "/public/coinix.png"
    },
    {
      "source": "/doge.png",
      "destination": "/public/doge.png"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}
